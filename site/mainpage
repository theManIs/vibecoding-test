	(function() {
    // Базовый URL, куда должна вести кнопка (без параметров)
    var baseUrl = 'https://usmanovafit.gymteam.ru/partnerregistration';

    // Параметры из текущего адреса
    var query = window.location.search; // пример: ?tgid=959551719&ambassid=368

    // Если параметров нет — просто переходим по базовой ссылке
    if (!query || query === '?') {
        window.location.href = baseUrl;
        return;
    }

    // Если в базовом URL уже есть свои параметры, аккуратно добавляем текущие
    var url;
    try {
        url = new URL(baseUrl, window.location.origin);
    } catch (e) {
        // запасной вариант, если URL() не поддерживается
        window.location.href = baseUrl + (baseUrl.indexOf('?') === -1 ? query : '&' + query.substring(1));
        return;
    }

    if (url.search) {
        // есть свои параметры → добавляем новые через &
        var existing = url.search.substring(1); // без ?
